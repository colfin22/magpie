# === THE BRAIN (required for decisions; without it every cycle logs a HOLD) ===
GEMINI_API_KEY=
#GEMINI_MODEL=gemini-2.5-flash

# === THE EXCHANGE (live mode only — paper mode needs no account at all) ===
# Create the API key with TRADE + QUERY permissions ONLY. Never grant withdrawal.
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
TRADING_ENABLED=false          # true + keys above = real money. Flip deliberately.

# === PORTFOLIO ===
#PAIRS=BTC/EUR,ETH/EUR         # the only pairs the bot may ever touch
#START_BALANCE_EUR=50          # paper-mode starting stake
#TAKER_FEE=0.004

# === NOTIFICATIONS (optional, Home Assistant) ===
#HA_URL=http://homeassistant.local:8123
#HA_TOKEN=your-long-lived-token
#HA_NOTIFY_SERVICE=notify.mobile_app_myphone
