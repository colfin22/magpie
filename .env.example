# === THE BRAIN (required for decisions; without it every cycle logs a HOLD) ===
GEMINI_API_KEY=
#GEMINI_MODEL=gemini-2.5-flash        # frequent decisions (swing/fortnight)
#GEMINI_MODEL_DEEP=gemini-2.5-pro     # rare decisions (quarter, vault) + monthly self-review

# === THE EXCHANGE (live mode only — paper mode needs no account at all) ===
# Create the API key with TRADE + QUERY permissions ONLY. Never grant withdrawal.
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
TRADING_ENABLED=false          # true + keys above = real money. Flip deliberately.

# === PORTFOLIO ===
#PAIRS=BTC/EUR,ETH/EUR         # the only pairs the bot may ever touch
#START_BALANCE_EUR=50          # paper-mode starting stake
#MAKER_FEE=0.0025              # post-only limit fee — the bot's preferred fill
#LIMIT_FILL_WAIT_S=90          # patience at the touch before falling back to market
#TAKER_FEE=0.004
#SKIM_FRACTION=0.5
#DYNAMIC_UNIVERSE=false        # auto-track the top-N altcoins by market cap (Kraken EUR pairs)
#DYNAMIC_TOP_N=5              # share of new profit skimmed into the vault sleeve

# === NOTIFICATIONS (optional, Home Assistant) ===
#HA_URL=http://homeassistant.local:8123
#HA_TOKEN=your-long-lived-token
#HA_NOTIFY_SERVICE=notify.mobile_app_myphone
#HA_NOTIFY_CLICK_URL=http://192.168.1.10:8000    # notifications open this URL when tapped

# === LOGIN (optional) ===
#DASHBOARD_PASSWORD=          # set to require login for the dashboard + controls; blank = open (LAN/your own proxy)
